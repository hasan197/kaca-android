<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_bg">

    <!-- ── Animated Background Circles ── -->
    <View
        android:id="@+id/vBgBlobTop"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="-60dp"
        android:layout_marginStart="-50dp"
        android:background="@drawable/bg_blob_top"
        android:alpha="0.5" />

    <View
        android:id="@+id/vBgBlobBottom"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="-80dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_blob_bottom"
        android:alpha="0.4" />

    <!-- ── Main Content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ═══ HEADER ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="52dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@color/brand_blue"
                    android:clipToOutline="true"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_smartphone"
                        android:scaleType="center"
                        android:importantForAccessibility="no" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kaca"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/neutral_900"
                        android:lineSpacingExtra="0dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v2.0 PROFESSIONAL"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_blue"
                        android:letterSpacing="0.15" />
                </LinearLayout>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_settings"
                android:scaleType="center"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="Settings"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btnHelp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_help"
                android:scaleType="center"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="Help" />
        </LinearLayout>

        <!-- ═══ MAIN CONTENT (state-based) ═══ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- ── STATE: INITIAL ── -->
            <LinearLayout
                android:id="@+id/stateInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Featured Card -->
                <LinearLayout
                    android:id="@+id/featuredCard"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_glass"
                    android:padding="32dp"
                    android:layout_marginBottom="16dp">

                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@color/brand_blue_soft"
                        android:clipToOutline="true"
                        android:layout_marginBottom="20dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_wifi"
                            android:scaleType="center"
                            android:importantForAccessibility="no" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mirror Anything"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/neutral_900"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hubungkan perangkat Android Anda\nke Mac secara instan dengan satu ketukan."
                        android:textSize="13sp"
                        android:textColor="@color/neutral_500"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>

                <!-- Action Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- Scan QR Button -->
                    <LinearLayout
                        android:id="@+id/btnScanAction"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="start|bottom"
                        android:background="@color/brand_blue"
                        android:padding="20dp"
                        android:layout_marginEnd="8dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="#33FFFFFF"
                            android:clipToOutline="true"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_camera"
                                android:scaleType="center"
                                android:importantForAccessibility="no" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cepat"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:textColor="#99FFFFFF"
                            android:letterSpacing="0.2"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scan QR"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <!-- Manual Button -->
                    <LinearLayout
                        android:id="@+id/btnManualAction"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="start|bottom"
                        android:background="@drawable/bg_glass"
                        android:padding="20dp"
                        android:layout_marginStart="8dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/neutral_100"
                            android:clipToOutline="true"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_activity"
                                android:scaleType="center"
                                android:importantForAccessibility="no" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kustom"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:textColor="@color/neutral_400"
                            android:letterSpacing="0.2"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manual"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/neutral_900" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ── STATE: SCANNING ── -->
            <LinearLayout
                android:id="@+id/stateScanning"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <!-- Scanner Frame -->
                <FrameLayout
                    android:id="@+id/scanFrame"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:background="@drawable/bg_scan_frame">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_camera"
                        android:scaleType="center"
                        android:alpha="0.15"
                        android:importantForAccessibility="no" />

                    <View
                        android:id="@+id/vScanLine"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@color/brand_blue"
                        android:alpha="0.6" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menunggu QR..."
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/neutral_900"
                    android:layout_marginTop="32dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Posisikan kamera di depan\nQR Code Kaca Mac Anda"
                    android:textSize="13sp"
                    android:textColor="@color/neutral_400"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="40dp" />

                <TextView
                    android:id="@+id/btnCancelScan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BATALKAN"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/neutral_600"
                    android:background="@drawable/bg_glass"
                    android:paddingHorizontal="32dp"
                    android:paddingVertical="12dp"
                    android:letterSpacing="0.12" />
            </LinearLayout>

            <!-- ── STATE: MANUAL ── -->
            <LinearLayout
                android:id="@+id/stateManual"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_glass"
                    android:padding="28dp"
                    android:gravity="center_vertical">

                    <!-- Manual header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="28dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Isi Manual"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/neutral_900" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Konfigurasi alamat host Mac"
                                android:textSize="11sp"
                                android:textColor="@color/neutral_400"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_info"
                            android:scaleType="center"
                            android:alpha="0.5"
                            android:importantForAccessibility="no" />
                    </LinearLayout>

                    <!-- Host Input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HOST ADDRESS"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:textColor="@color/neutral_400"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="6dp"
                            android:layout_marginStart="4dp" />

                        <EditText
                            android:id="@+id/etHost"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:paddingHorizontal="20dp"
                            android:paddingVertical="16dp"
                            android:textSize="13sp"
                            android:typeface="monospace"
                            android:hint="192.168.1.xxx"
                            android:textColorHint="@color/neutral_300"
                            android:textColor="@color/neutral_800"
                            android:inputType="text" />
                    </LinearLayout>

                    <!-- Port / Quality row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PORT"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:textColor="@color/neutral_400"
                                android:letterSpacing="0.15"
                                android:layout_marginBottom="6dp"
                                android:layout_marginStart="4dp" />

                            <EditText
                                android:id="@+id/etPort"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_input"
                                android:paddingHorizontal="20dp"
                                android:paddingVertical="16dp"
                                android:textSize="13sp"
                                android:typeface="monospace"
                                android:text="27183"
                                android:textColor="@color/neutral_800"
                                android:inputType="number" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="QUALITY"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:textColor="@color/neutral_400"
                                android:letterSpacing="0.15"
                                android:layout_marginBottom="6dp"
                                android:layout_marginStart="4dp" />

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <EditText
                                    android:id="@+id/etQuality"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_input"
                                    android:paddingHorizontal="20dp"
                                    android:paddingEnd="36dp"
                                    android:paddingVertical="16dp"
                                    android:textSize="13sp"
                                    android:typeface="monospace"
                                    android:text="75"
                                    android:textColor="@color/neutral_800"
                                    android:inputType="number" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="%"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/neutral_300"
                                    android:layout_alignEnd="@id/etQuality"
                                    android:layout_centerVertical="true"
                                    android:layout_marginEnd="16dp" />
                            </RelativeLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Connect Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStart"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="HUBUNGKAN SEKARANG"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:backgroundTint="@color/neutral_900"
                        app:cornerRadius="24dp"
                        app:icon="@drawable/ic_play_fill"
                        app:iconGravity="textStart"
                        app:iconSize="16dp"
                        android:layout_marginTop="24dp" />
                </LinearLayout>

                <!-- Back button -->
                <TextView
                    android:id="@+id/btnBackManual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="KEMBALI"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/neutral_400"
                    android:gravity="center"
                    android:letterSpacing="0.15"
                    android:paddingVertical="16dp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- ── STATE: CONNECTING ── -->
            <LinearLayout
                android:id="@+id/stateConnecting"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <FrameLayout
                    android:id="@+id/spinnerContainer"
                    android:layout_width="120dp"
                    android:layout_height="120dp">

                    <ProgressBar
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:indeterminateTint="@color/brand_blue"
                        style="?android:attr/progressBarStyleLarge" />

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_activity"
                        android:importantForAccessibility="no" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menyambungkan..."
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/neutral_900"
                    android:layout_marginTop="32dp" />

                <TextView
                    android:id="@+id/tvConnectingDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menyiapkan stream terenkripsi ke Mac Anda"
                    android:textSize="13sp"
                    android:textColor="@color/neutral_400"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="40dp" />

                <TextView
                    android:id="@+id/btnCancelConnect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BATALKAN"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_error"
                    android:background="@drawable/bg_cancel_button"
                    android:paddingHorizontal="32dp"
                    android:paddingVertical="12dp"
                    android:letterSpacing="0.12" />
            </LinearLayout>

        </FrameLayout>

        <!-- ═══ FOOTER STATUS BAR ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_glass"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="32dp"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/vFooterDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_circle"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvFooterStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SISTEM STANDBY"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:textColor="@color/neutral_500"
                    android:letterSpacing="0.12" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="6dp">

                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="@color/neutral_200" />

                    <View
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="@color/neutral_300" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAC DETECTED"
                    android:textSize="7sp"
                    android:textStyle="bold"
                    android:textColor="@color/neutral_400"
                    android:letterSpacing="0.15" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
