<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/brand_bg"
    android:paddingHorizontal="24dp">

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@color/brand_blue"
            android:clipToOutline="true"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_tab_container"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="K"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/neutral_900" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCREEN MIRRORING"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/brand_blue"
                android:alpha="0.6"
                android:letterSpacing="0.2" />

            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:background="@color/neutral_200"
                android:layout_marginHorizontal="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Android ke Mac"
                android:textSize="9sp"
                android:textColor="@color/neutral_400" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Tab Switcher ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_tab_container"
        android:layout_marginBottom="24dp">

        <!-- Sliding indicator -->
        <View
            android:id="@+id/vTabIndicator"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_tab_indicator"
            android:elevation="2dp" />

        <!-- Tab buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTabScan"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="SCAN QR"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/brand_blue"
                android:letterSpacing="0.2"
                android:background="@android:color/transparent" />

            <TextView
                android:id="@+id/tvTabManual"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="ISI MANUAL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/neutral_400"
                android:letterSpacing="0.2"
                android:background="@android:color/transparent" />

        </LinearLayout>

    </FrameLayout>

    <!-- ── Tab Content ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp">

        <!-- ═══ SCAN QR TAB ═══ -->
        <LinearLayout
            android:id="@+id/layoutScanTab"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="32dp">

                <!-- Badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cara Termudah"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_blue"
                    android:background="@color/brand_blue_soft"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:gravity="center"
                    android:letterSpacing="0.15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hubungkan via QR"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/neutral_900"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pindai kode QR yang muncul\ndi aplikasi Kaca Mac Anda"
                    android:textSize="13sp"
                    android:textColor="@color/neutral_400"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="28dp" />

                <!-- Camera frame -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_camera_frame"
                    android:layout_marginBottom="28dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="📷"
                        android:textSize="40sp"
                        android:alpha="0.4" />

                    <!-- Decorative corners -->

                </FrameLayout>

                <!-- Scan Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnScan"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="BUKA KAMERA"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    app:icon="@drawable/ic_camera"
                    app:iconGravity="textStart"
                    app:iconSize="20dp"
                    app:cornerRadius="16dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ═══ MANUAL TAB ═══ -->
        <LinearLayout
            android:id="@+id/layoutManualTab"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Konfigurasi IP"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/neutral_900" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gunakan jika QR Code tidak terbaca"
                    android:textSize="13sp"
                    android:textColor="@color/neutral_400"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="28dp" />

                <!-- Host IP -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOST IP MAC"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="@color/neutral_400"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="6dp"
                        android:layout_marginStart="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.Kaca.Input">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etHost"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="192.168.1.xxx"
                            android:inputType="text"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:background="@null" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- Port & Quality row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PORT"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/neutral_400"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="6dp"
                            android:layout_marginStart="4dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.Kaca.Input">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPort"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:text="27183"
                                android:background="@null" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KUALITAS"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/neutral_400"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="6dp"
                            android:layout_marginStart="4dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.Kaca.Input"
                            app:suffixText="%">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etQuality"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:text="75"
                                android:background="@null" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Start Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStart"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="MULAI MIRROR"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    app:icon="@drawable/ic_play_fill"
                    app:iconGravity="textStart"
                    app:iconSize="16dp"
                    app:cornerRadius="16dp"
                    android:backgroundTint="@color/neutral_900"
                    android:layout_marginTop="24dp" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- ── Status + Footer ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="16dp"
        android:layout_marginBottom="8dp">

        <!-- Status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_status_pill"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <FrameLayout
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp">

                <View
                    android:id="@+id/vStatusPulse"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_status_pulse" />

                <View
                    android:id="@+id/vStatusDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_circle" />

            </FrameLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sistem Siap"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/neutral_500"
                android:letterSpacing="0.12" />

        </LinearLayout>

        <!-- Help -->
        <LinearLayout
            android:id="@+id/btnHelp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_info"
                android:padding="8dp"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BANTUAN"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/neutral_400"
                android:letterSpacing="0.15" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Error ── -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:typeface="monospace"
        android:textColor="@color/status_error"
        android:textIsSelectable="true"
        android:visibility="gone"
        android:padding="12dp"
        android:background="@drawable/shape_error_bg"
        android:layout_marginBottom="16dp" />

</LinearLayout>
